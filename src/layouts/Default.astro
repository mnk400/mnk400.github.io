---
import { ClientRouter } from 'astro:transitions';
import { site } from '../data/site.ts';
import Header from '../components/Header.astro';
import StructuredData from '../components/StructuredData.astro';
import { themes, defaultTheme } from '../lib/theme.ts';
import { fonts, defaultFont } from '../lib/font.ts';
import { getBreadcrumbs } from '../lib/breadcrumbs.ts';
import '@fontsource/inter/200.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/700.css';
import '../styles/main.scss';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  useMath?: boolean;
  styles?: string[];
  pageTitle?: string; // optional breadcrumb label override
  entity?: { type?: string; name?: string; same_as?: string[] };
  schemaType?: string;
  layoutKind?: string; // analog of page.layout (post / product)
}

const {
  title,
  description = site.description,
  image,
  useMath = false,
  styles = [],
  pageTitle,
  entity,
  schemaType,
  layoutKind,
} = Astro.props;

const pathname = Astro.url.pathname;
const origin = Astro.site!.origin;
const canonical = `${origin}${pathname}`;
const breadcrumbs = getBreadcrumbs(pathname, pageTitle ?? title);

// Build-time OG card: deterministic /og/<slug>.png url per page. The og-images
// integration (see astro.config.mjs) walks dist/**/*.html post-build and renders
// each card via satori + sharp, using the page title + the local hero image
// emitted in the x-og-source meta below.
const ogSlug = pathname.replace(/^\/|\/$/g, '').replace(/\//g, '-') || 'home';
const heroIsLocal = image && !image.includes('://');
const ogImageUrl = `${origin}/og/${ogSlug}.png`;

const pageTitleFull = title ? `${title} — Manik` : 'Manik';
const ogTitle = title ? `${title} — Manik` : 'Manik';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />

    <meta name="author" content="Manik Kumar" />
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    {heroIsLocal && <meta name="x-og-source" content={image} />}
    <title>{pageTitleFull}</title>

    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="icon" href="/assets/images/site/favicon.ico" />

    <!-- Pre-paint theme + font apply. Runs synchronously before CSS so the
         page never flashes the wrong palette. Data is sourced from the same
         lib modules the switcher components use, via define:vars. -->
    <script is:inline define:vars={{ themes, defaultTheme, fonts, defaultFont }}>
      // @ts-nocheck -- variables in this pre-paint script are injected by Astro define:vars.
      (function () {
        var themeNames = themes.map(function (t) { return t.name; });
        var fontNames = fonts.map(function (f) { return f.name; });

        var urlTheme = new URL(location.href).searchParams.get('theme');
        var storedTheme = localStorage.getItem('theme');
        var themeName =
          urlTheme && themeNames.indexOf(urlTheme) !== -1 ? urlTheme :
          storedTheme && themeNames.indexOf(storedTheme) !== -1 ? storedTheme :
          defaultTheme;
        var theme = themes.find(function (t) { return t.name === themeName; });
        document.documentElement.setAttribute('data-theme', themeName);
        var metaTag = document.querySelector('meta[name="theme-color"]');
        if (!metaTag) {
          metaTag = document.createElement('meta');
          metaTag.name = 'theme-color';
          document.head.appendChild(metaTag);
        }
        metaTag.content = theme.meta;

        var storedFont = localStorage.getItem('font');
        var fontName =
          storedFont && fontNames.indexOf(storedFont) !== -1 ? storedFont : defaultFont;
        var font = fonts.find(function (f) { return f.name === fontName; });
        document.documentElement.style.setProperty('--font-family', font.stack);
        document.documentElement.style.setProperty(
          '--font-size-scale',
          String(font.scale != null ? font.scale : 1),
        );
      })();
    </script>

    <ClientRouter />

    <!-- View transition direction + breadcrumb-name swap on home↔sub navs.
         Same-document via ClientRouter; pageswap/pagereveal of the old MPA
         model become astro:before-preparation and astro:before-swap.
         Plain (bundled) script: runs once, registers document listeners
         that survive DOM swaps. -->
    <script>
      (function () {
        var breadcrumbSelectors = ['.breadcrumb-back', '.breadcrumb-home', '.breadcrumb-sep'];

        function setBreadcrumbNames(doc: Document, value: string) {
          breadcrumbSelectors.forEach(function (sel) {
            var el = doc.querySelector<HTMLElement>(sel);
            if (el) el.style.viewTransitionName = value;
          });
        }

        function isHomePage(url: URL | string) {
          var path = url instanceof URL ? url.pathname : new URL(url, location.origin).pathname;
          return path === '/' || path === '/index.html';
        }

        document.addEventListener('astro:before-preparation', function (event) {
          if (isHomePage(event.to)) {
            setBreadcrumbNames(document, 'none');
          }
        });

        document.addEventListener('astro:before-swap', function (event) {
          event.newDocument.documentElement.dataset.vtDirection = event.direction;

          if (isHomePage(event.from)) {
            setBreadcrumbNames(event.newDocument, 'none');
          }

          if (event.viewTransition && event.viewTransition.finished) {
            event.viewTransition.finished.finally(function () {
              delete document.documentElement.dataset.vtDirection;
              setBreadcrumbNames(document, '');
            });
          }
        });
      })();
    </script>

    {styles.map(href => (
      <link rel="stylesheet" type="text/css" href={href} />
    ))}

    <!-- Google Analytics -->
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-WLJ3VCYPD9"></script>
    <meta name="p:domain_verify" content="bba1d80d0778741b7525ee227f44f5ff" />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-WLJ3VCYPD9');
    </script>

    <StructuredData
      url={pathname}
      socialImageUrl={ogImageUrl}
      schemaType={schemaType}
      title={title}
      description={description}
      layout={layoutKind}
      entity={entity}
      breadcrumbs={breadcrumbs}
    />

    {useMath && (
      <>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.1/MathJax.js?config=TeX-AMS-MML_HTMLorMML" is:inline></script>
        <script src="//ajax.googleapis.com/ajax/libs/jquery/2.0.0/jquery.min.js" is:inline></script>
        <script type="text/x-mathjax-config" is:inline>
          MathJax.Hub.Config({ "HTML-CSS" : { availableFonts : ["Tex"], scale : 70 } });
        </script>
      </>
    )}
  </head>
  <body>
    <div class="wrapper">
      <Header pathname={pathname} breadcrumbs={breadcrumbs} />
      <main class="page-content">
        <slot />
      </main>
    </div>

    <!-- Custom element registration + delegated click handler for the
         <zoomable-image> lightbox. Bundled module — runs once globally and
         survives DOM swaps. -->
    <script>
      import '../lib/image-zoom.ts';
    </script>

    <!-- Global page-chrome behaviors: scroll class toggle on <html> + touch
         hover visual feedback. Both registered once on document; survive DOM
         swaps because the listeners aren't on swapped elements. -->
    <script>
      // Scroll class on <html>: CSS toggles header state when scrollY > 30.
      let ticking = false;
      function updateScrollClass() {
        document.documentElement.classList.toggle('is-scrolled', window.scrollY > 30);
        ticking = false;
      }
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateScrollClass);
          ticking = true;
        }
      }, { passive: true });
      // Run on initial paint and after every client-side nav (scroll resets to 0).
      document.addEventListener('astro:page-load', updateScrollClass);

      // Touch-hover: visual tap feedback for mobile.
      if ('ontouchstart' in window) {
        const SELECTORS = 'a, button, .btn, .switch-option, .selection-dropdown__trigger, .selection-dropdown__option, .expandable-toggle, .site-search__trigger';
        let touchStart = 0;
        let activeTarget: Element | null = null;

        document.addEventListener('touchstart', (e) => {
          activeTarget = (e.target as Element).closest(SELECTORS);
          if (activeTarget) {
            touchStart = Date.now();
            activeTarget.classList.add('touch-hover');
          }
        }, { passive: true });

        const endTouch = () => {
          if (!activeTarget) return;
          const elapsed = Date.now() - touchStart;
          const target = activeTarget;
          activeTarget = null;
          setTimeout(
            () => target.classList.remove('touch-hover'),
            Math.max(0, 150 - elapsed),
          );
        };
        document.addEventListener('touchend', endTouch, { passive: true });
        document.addEventListener('touchcancel', endTouch, { passive: true });
      }
    </script>
  </body>
</html>
