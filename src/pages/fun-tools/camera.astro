---
import Post from '../../layouts/Post.astro';
import SelectionSwitch from '../../components/SelectionSwitch.astro';
import { cameraModes } from '../../lib/camera-modes/index.ts';

const modeOptions = cameraModes.map((m) => ({ value: m.id, label: m.label }));
---
<Post
  title="Camera Art"
  description="Convert your camera feed into real-time ASCII or circle art"
>
  <p>See yourself live as ASCII or circles.</p>

  <div class="ascii-container stack">
    <video id="video" style="display: none;"></video>

    <div class="stack">
      <div class="range-slider" data-range-slider>
        <p class="range-value">Detail · <span id="detail-value">33</span></p>
        <input type="range" id="detail-input" value="33" min="0" max="100" />
      </div>

      <div class="field">
        <span class="field__label">mode</span>
        <SelectionSwitch
          id="camera-mode-toggle"
          options={modeOptions}
          active={modeOptions[0].value}
          size="small"
        />
      </div>

      <div class="toolbar">
        <button id="start-btn" class="normal-btn">Start Camera</button>
        <button id="fullscreen-btn" class="normal-btn">Fullscreen</button>
      </div>
    </div>

    <div class="canvas-container">
      <canvas id="camera-canvas"></canvas>
    </div>
  </div>
</Post>

<script>
  import { createCameraManager } from '../../lib/camera-manager.ts';
  import { cameraModes } from '../../lib/camera-modes/index.ts';
  import type { CameraMode } from '../../lib/camera-modes/types.ts';

  function initCameraArt() {
    const video = document.getElementById('video') as HTMLVideoElement | null;
    const canvas = document.getElementById('camera-canvas') as HTMLCanvasElement | null;
    const detailInput = document.getElementById('detail-input') as HTMLInputElement | null;
    const detailValue = document.getElementById('detail-value');
    const startBtn = document.getElementById('start-btn') as HTMLButtonElement | null;
    const fullscreenBtn = document.getElementById('fullscreen-btn') as HTMLButtonElement | null;
    const modeToggle = document.getElementById('camera-mode-toggle');

    if (!video || !canvas || !detailInput || !startBtn || !fullscreenBtn) return;
    if (canvas.dataset.cameraArtInitialized === 'true') return;
    canvas.dataset.cameraArtInitialized = 'true';

    const ctx = canvas.getContext('2d')!;
    let activeMode: CameraMode = cameraModes[0];

    function cssSize() {
      if (camera.isFullscreen()) return { w: window.innerWidth, h: window.innerHeight };
      const w = canvas!.parentElement!.clientWidth;
      return { w, h: Math.round((w * 3) / 4) }; // 4:3 to match the feed
    }

    // Size the backing store for the device pixel ratio so canvas text stays
    // crisp, then scale the context so modes can draw in CSS pixels.
    function applyCanvasSize() {
      const dpr = window.devicePixelRatio || 1;
      const { w, h } = cssSize();
      canvas!.width = Math.round(w * dpr);
      canvas!.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function renderFrame(v: HTMLVideoElement) {
      const dpr = window.devicePixelRatio || 1;
      const { w, h } = cssSize();
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, w, h);
      activeMode.render({
        ctx,
        video: v,
        width: w,
        height: h,
        detail: parseInt(detailInput!.value),
        fullscreen: camera.isFullscreen(),
      });
    }

    detailInput.addEventListener('input', () => {
      if (detailValue) detailValue.textContent = detailInput.value;
    });

    modeToggle?.addEventListener('change', (e) => {
      const id = (e as CustomEvent<{ value: string }>).detail.value;
      activeMode = cameraModes.find((m) => m.id === id) ?? activeMode;
      if (!camera.isRunning()) {
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.clearRect(0, 0, canvas!.width, canvas!.height);
      }
    });

    const camera = createCameraManager({
      video,
      startBtn,
      fullscreenBtn,
      fullscreenTarget: canvas,
      render: renderFrame,
      onStart() {
        applyCanvasSize();
      },
      onStop() {
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.clearRect(0, 0, canvas!.width, canvas!.height);
      },
      onEnterFullscreen() {
        canvas!.classList.add('is-fullscreen');
        applyCanvasSize();
      },
      onExitFullscreen() {
        canvas!.classList.remove('is-fullscreen');
        applyCanvasSize();
        detailInput!.value = '33';
        if (detailValue) detailValue.textContent = '33';
      },
    });

    function onResize() {
      applyCanvasSize();
    }
    window.addEventListener('resize', onResize);

    document.addEventListener('astro:before-swap', () => {
      camera.stop();
      window.removeEventListener('resize', onResize);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initCameraArt);
</script>
