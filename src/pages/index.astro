---
import { getCollection } from 'astro:content';
import Default from '../layouts/Default.astro';
import ExpandableSection from '../components/ExpandableSection.astro';
import MusicWidget from '../components/MusicWidget.astro';
import Footer from '../components/Footer.astro';

const allPosts = await getCollection('posts');
const posts = allPosts
  .map((post) => {
    const match = post.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/)!;
    const [, y, m, d, slug] = match;
    const date = post.data.date ?? new Date(`${y}-${m}-${d}T00:00:00Z`);
    return {
      title: post.data.title,
      url: `/${y}/${m}/${d}/${slug}`,
      date,
      monthYear: date
        .toLocaleDateString('en-US', { month: 'short', year: '2-digit', timeZone: 'UTC' })
        .replace(' ', '-'),
    };
  })
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---
<Default
  description="Manik's personal website and blog"
  scripts={['/assets/js/media/lastfm.js', '/assets/js/location-time.js']}
>
  <div class="home stack stack--md">
    <div class="home__intro stack stack--sm">
      <p>
        Hi! I am
        <b>
          <button type="button" class="site-title-link" data-photo-reveal="/assets/images/site/me.jpg">Manik</button>,
        </b>
        a software developer who lives in Seattle, these days I help build software for
        <b>
          <button type="button" class="site-title-link" data-photo-reveal="/assets/images/site/kindle.png">
            Kindle
          </button>
        </b>
        apps and devices. I graduated from
        <b>
          <button type="button" class="site-title-link" data-photo-reveal="/assets/images/site/paws.jpg">
            Northeastern University
          </button>
        </b>
        in Boston.
      </p>
      <p>
        I'm also an amateur photographer who spends a lot of my free time
        exploring photography.
      </p>
    </div>

    <ExpandableSection id="blog-archive" class="expandable-section--compact" title="<b>Archive</b>">
      <div class="archive">
        <ul>
          {posts.map(post => (
            <li>
              <a href={post.url}>{post.title}</a>
              <span class="date">{post.monthYear}</span>
            </li>
          ))}
        </ul>
      </div>
    </ExpandableSection>

    <div class="music-widget-section stack stack--sm">
      <div class="music-widget-header">
        <span class="music-widget-label" id="music-widget-label">
          Last listened to …
        </span>
        <span class="music-widget-time-wrapper">
          <span class="music-widget-time-placeholder">…</span>
          <span class="music-widget-time" id="music-widget-time"></span>
        </span>
      </div>
      <MusicWidget />
    </div>
    <div></div>
    <Footer />
  </div>
</Default>
