---
import Post from '../../../layouts/Post.astro';
import ArchiveIndex from '../../../components/ArchiveIndex.astro';
import { getMoreGroups } from '../../../lib/more.ts';

const group = getMoreGroups().find((entry) => entry.path === 'archive/things');
const hub = group?.hub;
const things = group?.items ?? [];
---
<Post
  title={hub?.title ?? 'Archive of Things'}
  description={hub?.description}
  image={hub?.image}
>
  <p>
    A small browser for objects, gear, and physical things I like, each archive is searchable and image-led.
  </p>

  <ArchiveIndex items={things} idPrefix="thing" emptyText="No thing archives are live yet." />
</Post>
