---
import Post from '../../layouts/Post.astro';
import ExpandableSection from '../../components/ExpandableSection.astro';
---
<Post
  title="Colordle"
  description="Guess the hex color code in 6 tries"
  image="/assets/images/previews/colordle.jpg"
>
  <div class="colordle-container">
    <div class="stack stack--md">
      <p>Guess the hex color code in 6 tries!</p>

      <ExpandableSection id="how-to-play" title="<b>How to Play</b>">
        <p>Guess the target color's hex code in 6 tries.</p>
        <ul>
          <li>Enter a valid hex color code (e.g., #FF5733)</li>
          <li>After each guess, you'll see how close you are:</li>
          <li><span class="feedback-example correct"></span> Correct hex digit in the right position</li>
          <li><span class="feedback-example close"></span> Correct hex digit in the wrong position</li>
          <li><span class="feedback-example wrong"></span> Hex digit not in the target color</li>
        </ul>
        <p>The color swatch shows your guessed color vs the target.</p>
      </ExpandableSection>

      <div id="colordle-meta">
        <span>target color</span>
        <span><span id="guess-count">0</span>/6</span>
      </div>
    </div>

    <div class="color-display" id="color-display"></div>

    <div class="game-board" id="game-board"></div>

    <div class="input-section" id="input-section">
      <input type="text" id="guess-input" placeholder="#000000" maxlength="7" pattern="^#[0-9A-Fa-f]{6}$" />
      <button id="submit-guess" class="normal-btn">Guess</button>
    </div>

    <div class="game-message" id="game-message"></div>

    <div class="game-results" id="game-results" style="display: none;">
      <div class="game-stats" id="game-stats">
        <h3>Statistics</h3>
        <div class="stats-grid">
          <div class="stat">
            <div class="stat-number" id="games-played">0</div>
            <div class="stat-label">Played</div>
          </div>
          <div class="stat">
            <div class="stat-number" id="win-percentage">0</div>
            <div class="stat-label">Win %</div>
          </div>
          <div class="stat">
            <div class="stat-number" id="current-streak">0</div>
            <div class="stat-label">Current Streak</div>
          </div>
          <div class="stat">
            <div class="stat-number" id="max-streak">0</div>
            <div class="stat-label">Max Streak</div>
          </div>
        </div>
      </div>

      <div class="share-section">
        <button id="share-results" class="normal-btn">Share Results</button>
        <div id="share-text" class="share-text" style="display: none;"></div>
      </div>
    </div>
  </div>
</Post>

<script>
  import { copyText } from '../../lib/clipboard.ts';

  interface GuessEntry {
    guess: string;
    feedback: string[];
  }

  interface ColordleStats {
    gamesPlayed: number;
    wins: number;
    currentStreak: number;
    maxStreak: number;
  }

  class Colordle {
    targetColor = '';
    guesses: GuessEntry[] = [];
    currentGuess = 0;
    maxGuesses = 6;
    gameOver = false;
    stats: ColordleStats;
    colors: string[] = [];
    todayDate: string;

    constructor() {
      this.stats = this.loadStats();
      this.todayDate = this.getTodayDateString();

      this.loadColors().then(() => {
        this.initializeGame();
        this.bindEvents();
      });
    }

    async loadColors() {
      try {
        const response = await fetch('/assets/data/colordle-colors.json');
        const data = await response.json();
        this.colors = data.colors;
      } catch (error) {
        console.error('Failed to load colors:', error);
        this.colors = [
          '#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4', '#FFEAA7', '#DDA0DD', '#98D8C8', '#F7DC6F',
          '#BB8FCE', '#85C1E9', '#F8C471', '#82E0AA', '#F1948A', '#85C1E9', '#F4D03F', '#A9DFBF',
        ];
      }
    }

    getTodayDateString() {
      const today = new Date();
      return `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
    }

    initializeGame() {
      const savedGame = this.loadTodaysGame();

      if (savedGame && savedGame.date === this.todayDate) {
        this.targetColor = savedGame.targetColor;
        this.guesses = savedGame.guesses || [];
        this.currentGuess = savedGame.currentGuess || 0;
        this.gameOver = savedGame.gameOver || false;

        this.renderTargetColor();
        this.renderGameBoard();
        this.restoreGameState();
      } else {
        this.generateTodaysTargetColor();
        this.renderTargetColor();
        this.renderGameBoard();
        this.saveTodaysGame();
      }

      this.updateGuessCount();
      this.updateStats();
    }

    generateTodaysTargetColor() {
      const dateHash = this.hashCode(this.todayDate);
      const colorIndex = Math.abs(dateHash) % this.colors.length;
      this.targetColor = this.colors[colorIndex];
    }

    hashCode(str: string) {
      let hash = 0;
      for (let i = 0; i < str.length; i++) {
        const char = str.charCodeAt(i);
        hash = ((hash << 5) - hash) + char;
        hash = hash & hash;
      }
      return hash;
    }

    renderTargetColor() {
      const colorDisplay = document.getElementById('color-display') as HTMLElement;
      colorDisplay.style.backgroundColor = this.targetColor;
    }

    updateGuessCount() {
      const counter = document.getElementById('guess-count');
      if (counter) counter.textContent = String(this.currentGuess);
    }

    renderGameBoard() {
      const gameBoard = document.getElementById('game-board') as HTMLElement;
      gameBoard.innerHTML = '';

      for (let i = 0; i < this.maxGuesses; i++) {
        const row = document.createElement('div');
        row.className = 'guess-row';
        row.innerHTML = `
          <div class="hex-cells">
            <div class="hex-cell hash-cell">#</div>
            ${Array(6).fill('<div class="hex-cell empty-cell"></div>').join('')}
          </div>
        `;
        gameBoard.appendChild(row);
      }
    }

    bindEvents() {
      const guessInput = document.getElementById('guess-input') as HTMLInputElement;
      const submitButton = document.getElementById('submit-guess') as HTMLButtonElement;
      const shareButton = document.getElementById('share-results') as HTMLButtonElement;

      submitButton.addEventListener('click', () => this.submitGuess());
      guessInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') this.submitGuess();
      });

      guessInput.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        let value = target.value.toUpperCase();
        if (!value.startsWith('#')) {
          value = '#' + value.replace('#', '');
        }
        target.value = value;
      });

      shareButton.addEventListener('click', () => this.shareResults());
    }

    submitGuess() {
      if (this.gameOver) return;

      const guessInput = document.getElementById('guess-input') as HTMLInputElement;
      const guess = guessInput.value.toUpperCase();

      if (!this.isValidHex(guess)) {
        this.showMessage('Please enter a valid hex color code (e.g., #FF5733)', 'error');
        return;
      }

      this.processGuess(guess);
      guessInput.value = '';

      if (guess === this.targetColor) {
        this.endGame(true);
      } else if (this.currentGuess >= this.maxGuesses) {
        this.endGame(false);
      }
    }

    isValidHex(hex: string) {
      return /^#[0-9A-F]{6}$/i.test(hex);
    }

    processGuess(guess: string) {
      const row = document.querySelectorAll('.guess-row')[this.currentGuess];
      const hashCell = row.querySelector('.hex-cell.hash-cell') as HTMLElement;
      const hexCells = row.querySelectorAll('.hex-cell:not(.hash-cell)');

      hashCell.style.backgroundColor = guess;

      const feedback = this.generateFeedback(guess);
      const guessHex = guess.slice(1);

      hexCells.forEach((cell, index) => {
        cell.textContent = guessHex[index];
        cell.className = `hex-cell ${feedback[index] === '🟢' ? 'correct' :
          feedback[index] === '🟡' ? 'close' : 'wrong'}`;
      });

      this.guesses.push({ guess, feedback });

      this.currentGuess++;
      this.updateGuessCount();
      this.saveTodaysGame();
    }

    generateFeedback(guess: string) {
      const target = this.targetColor.slice(1);
      const guessHex = guess.slice(1);
      const feedback: string[] = [];

      const targetChars = target.split('');
      const guessChars = guessHex.split('');
      const usedTargetIndices = new Set<number>();
      const usedGuessIndices = new Set<number>();

      for (let i = 0; i < 6; i++) {
        if (guessChars[i] === targetChars[i]) {
          feedback[i] = '🟢';
          usedTargetIndices.add(i);
          usedGuessIndices.add(i);
        }
      }

      for (let i = 0; i < 6; i++) {
        if (usedGuessIndices.has(i)) continue;

        let found = false;
        for (let j = 0; j < 6; j++) {
          if (usedTargetIndices.has(j)) continue;
          if (guessChars[i] === targetChars[j]) {
            feedback[i] = '🟡';
            usedTargetIndices.add(j);
            found = true;
            break;
          }
        }

        if (!found) {
          feedback[i] = '⚫';
        }
      }

      return feedback;
    }

    endGame(won: boolean) {
      this.gameOver = true;
      const inputSection = document.getElementById('input-section') as HTMLElement;
      inputSection.style.display = 'none';

      if (won) {
        this.showMessage(`🎉 Congratulations! You guessed ${this.targetColor} in ${this.currentGuess} tries! Come back tomorrow for a new challenge.`, 'success');
        this.stats.wins++;
        this.stats.currentStreak++;
        this.stats.maxStreak = Math.max(this.stats.maxStreak, this.stats.currentStreak);
      } else {
        this.showMessage(`😞 Game over! The color was ${this.targetColor}. Come back tomorrow for a new challenge.`, 'error');
        this.stats.currentStreak = 0;
      }

      this.stats.gamesPlayed++;
      this.saveStats();
      this.updateStats();
      this.saveTodaysGame();

      (document.getElementById('game-results') as HTMLElement).style.display = 'block';
    }

    showMessage(message: string, type: string) {
      const messageDiv = document.getElementById('game-message') as HTMLElement;
      messageDiv.textContent = message;
      messageDiv.className = `game-message ${type}`;

      if (type === 'error' && message.includes('Please enter a valid')) {
        setTimeout(() => {
          messageDiv.textContent = '';
          messageDiv.className = 'game-message';
        }, 3000);
      }
    }

    loadStats(): ColordleStats {
      const saved = localStorage.getItem('colordle-stats');
      return saved ? JSON.parse(saved) : {
        gamesPlayed: 0,
        wins: 0,
        currentStreak: 0,
        maxStreak: 0,
      };
    }

    saveStats() {
      localStorage.setItem('colordle-stats', JSON.stringify(this.stats));
    }

    loadTodaysGame() {
      const saved = localStorage.getItem('colordle-daily-game');
      return saved ? JSON.parse(saved) : null;
    }

    saveTodaysGame() {
      const gameState = {
        date: this.todayDate,
        targetColor: this.targetColor,
        guesses: this.guesses,
        currentGuess: this.currentGuess,
        gameOver: this.gameOver,
      };
      localStorage.setItem('colordle-daily-game', JSON.stringify(gameState));
    }

    restoreGameState() {
      this.guesses.forEach((guessData, index) => {
        const row = document.querySelectorAll('.guess-row')[index];
        const hashCell = row.querySelector('.hex-cell.hash-cell') as HTMLElement;
        const hexCells = row.querySelectorAll('.hex-cell:not(.hash-cell)');

        hashCell.style.backgroundColor = guessData.guess;

        const guessHex = guessData.guess.slice(1);

        hexCells.forEach((cell, cellIndex) => {
          cell.textContent = guessHex[cellIndex];
          cell.className = `hex-cell ${guessData.feedback[cellIndex] === '🟢' ? 'correct' :
            guessData.feedback[cellIndex] === '🟡' ? 'close' : 'wrong'}`;
        });
      });

      if (this.gameOver) {
        const inputSection = document.getElementById('input-section') as HTMLElement;
        inputSection.style.display = 'none';

        const won = this.guesses.length > 0 && this.guesses[this.guesses.length - 1].guess === this.targetColor;
        if (won) {
          this.showMessage(`🎉 You completed today's Colordle! Come back tomorrow for a new challenge.`, 'success');
        } else {
          this.showMessage(`😞 You didn't get today's color: ${this.targetColor}. Come back tomorrow for a new challenge.`, 'error');
        }

        (document.getElementById('game-results') as HTMLElement).style.display = 'block';
      }
    }

    updateStats() {
      (document.getElementById('games-played') as HTMLElement).textContent = String(this.stats.gamesPlayed);
      (document.getElementById('win-percentage') as HTMLElement).textContent = String(
        this.stats.gamesPlayed > 0 ? Math.round((this.stats.wins / this.stats.gamesPlayed) * 100) : 0,
      );
      (document.getElementById('current-streak') as HTMLElement).textContent = String(this.stats.currentStreak);
      (document.getElementById('max-streak') as HTMLElement).textContent = String(this.stats.maxStreak);
    }

    shareResults() {
      const shareText = this.generateShareText();
      const shareTextDiv = document.getElementById('share-text') as HTMLElement;
      const shareButton = document.getElementById('share-results') as HTMLButtonElement;

      shareTextDiv.textContent = shareText;
      shareTextDiv.style.display = 'block';

      copyText(shareText).then((ok) => {
        if (ok) {
          shareButton.textContent = 'Copied!';
          setTimeout(() => { shareButton.textContent = 'Share Results'; }, 2000);
        } else {
          (shareTextDiv as unknown as HTMLInputElement).select?.();
          shareButton.textContent = 'Select text above to copy';
          setTimeout(() => { shareButton.textContent = 'Share Results'; }, 3000);
        }
      });
    }

    generateShareText() {
      const won = this.gameOver && this.guesses.length > 0 && this.guesses[this.guesses.length - 1].guess === this.targetColor;
      const attempts = won ? this.currentGuess : 'X';

      let shareText = `Colordle ${this.todayDate}\n`;
      shareText += `${attempts}/6\n\n`;

      this.guesses.forEach((guessData) => {
        const row = guessData.feedback.map((feedback) => {
          if (feedback === '🟢') return '🟩';
          if (feedback === '🟡') return '🟨';
          return '⬛';
        }).join('');
        shareText += row + '\n';
      });

      shareText += `\nPlay at: ${window.location.origin}/games/colordle`;

      return shareText;
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('color-display')) return;
    new Colordle();
  });
</script>
