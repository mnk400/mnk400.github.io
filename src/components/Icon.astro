---
type IconWeight = 'bold' | 'fill';

interface Props {
  name: string;
  weight?: IconWeight;
  class?: string;
}

const { name, weight = 'bold', class: extraClass } = Astro.props;

const icons = import.meta.glob<string>('/_includes/icons/**/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});

const key = `/_includes/icons/${weight}/${name}.svg`;
const raw = icons[key];
if (!raw) {
  throw new Error(`Icon not found: ${weight}/${name}. Add ${key} or check the name.`);
}

const classes = ['icon', extraClass].filter(Boolean).join(' ');
const svg = raw.replace('<svg', `<svg class="${classes}" aria-hidden="true"`);
---
<Fragment set:html={svg} />
