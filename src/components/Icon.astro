---
import { Icon as IconifyIcon } from 'astro-icon/components';

// Site-wide icon component. Wraps Iconify so the rest of the codebase
// never has to know which icon set is underneath — to switch sets
// later, this file is the only one that changes.
type IconWeight = 'thin' | 'light' | 'regular' | 'bold' | 'fill' | 'duotone';

interface Props {
  name: string;
  weight?: IconWeight;
  class?: string;
}

const { name, weight = 'bold', class: extraClass } = Astro.props;
const resolved = weight === 'regular' ? `ph:${name}` : `ph:${name}-${weight}`;
const classes = ['icon', extraClass].filter(Boolean).join(' ');
---
<IconifyIcon name={resolved} class={classes} aria-hidden="true" />
