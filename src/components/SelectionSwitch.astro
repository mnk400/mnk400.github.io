---
interface SwitchOption {
  value: string;
  label: string;
}

interface Props {
  id: string;
  options: SwitchOption[];
  active?: string;
  class?: string;
}

const { id, options, active, class: extraClass } = Astro.props;
const activeValue = active ?? options[0]?.value;

const classes = ['selection-switch', extraClass].filter(Boolean).join(' ');
---
<div class={classes} id={id} data-selection-switch>
  {options.map(opt => (
    <span
      id={opt.value}
      class:list={['switch-option', { active: opt.value === activeValue }]}
      data-value={opt.value}
    >{opt.label}</span>
  ))}
</div>

<script>
  import { initSelectionControls } from '../lib/selection-controls.ts';

  document.addEventListener('astro:page-load', () => initSelectionControls());
</script>
