---
import Icon from './Icon.astro';

interface Props {
  external?: boolean;
}

const { external = false } = Astro.props;
const href = external ? 'https://www.last.fm/user/mnk_400' : '/music/music';
---
<a
  href={href}
  class="music-widget"
  id="music-widget"
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  <div class="music-widget-content">
    <div class="music-widget-art-wrapper">
      <div class="music-widget-art-placeholder"></div>
      <img
        id="music-widget-art"
        class="music-widget-art"
        src="/assets/images/site/album-placeholder.png"
        alt="Album art"
      />
    </div>
    <div class="music-widget-info">
      <span class="music-widget-info-placeholder">Loading track…</span>
      <span id="music-widget-track" class="music-widget-track"></span>
      <span class="music-widget-separator"> — </span>
      <span id="music-widget-artist" class="music-widget-artist"></span>
    </div>
    <div class="music-widget-status" id="music-widget-status">
      <span class="music-widget-status-icon" aria-hidden="true">∿</span>
      <span class="music-widget-status-label" id="music-widget-label"></span>
      <span class="music-widget-status-time" id="music-widget-time"></span>
    </div>
    <Icon name={external ? 'arrow-up-right' : 'arrow-right'} class="music-widget-arrow" />
  </div>
</a>

<script>
  import { initMusicWidget } from '../lib/lastfm.ts';
  document.addEventListener('astro:page-load', initMusicWidget);
</script>
