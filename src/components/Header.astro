---
import SettingsPanel from './SettingsPanel.astro';
import Icon from './Icon.astro';
import type { BreadcrumbItem } from '../lib/breadcrumbs.ts';

interface Props {
  pathname: string;
  pageTitle?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { pathname, pageTitle, breadcrumbs = [] } = Astro.props;
const isHome = pathname === '/' || pathname === '/index.html';
const displayBreadcrumbs = breadcrumbs.length > 0
  ? breadcrumbs
  : pageTitle
    ? [{ label: pageTitle, href: pathname, current: true }]
    : [];
---
<header>
  <div class="title-photo-container" id="titlePhotoContainer">
    <img src="/assets/images/site/me.jpg" alt="Manik" class="title-photo" />
  </div>

  <SettingsPanel />

  <div class="header-row">
    <div class="header-left">
      {isHome ? (
        <div class="site-name-group">
          <div class="site-name-lockup">
            <button
              type="button"
              class="site-name"
              id="title-photo-trigger"
              data-site-name-trigger
            >Manik</button>
            <img
              src="/assets/images/site/favicon.ico"
              alt=""
              class="site-name-flower"
              aria-hidden="true"
              decoding="sync"
              fetchpriority="high"
            />
          </div>
          <div class="site-name-menu" id="siteNameMenu">
            <a href="/more/">more</a>
            <a href="/photos/">photos</a>
            <a href="https://linkedin.com/in/manik-kumar" target="_blank">linkedin</a>
            <a href="mailto:me@manik.cc">email</a>
            <span class="menu-sep">/</span>
            <button type="button" class="menu-trigger" data-settings-trigger><span class="settings-toggle-text">settings</span></button>
          </div>
        </div>
      ) : (
        <nav class="header-breadcrumb">
          <button type="button" class="breadcrumb-back" data-back-nav>
            <Icon name="arrow-down-left" />
          </button>
          <a href="/" class="breadcrumb-home">Manik</a>
          {displayBreadcrumbs.map((item) => (
            <>
              <span class:list={['breadcrumb-sep', { 'breadcrumb-root-sep': item === displayBreadcrumbs[0] }]}>/</span>
              {item.current ? (
                <span class="breadcrumb-current">{item.label}</span>
              ) : (
                <a href={item.href} class="breadcrumb-mid">{item.label}</a>
              )}
            </>
          ))}
        </nav>
      )}
    </div>
  </div>
</header>

<script>
  // Photo reveal animation (used by the site-name in header AND any
  // [data-photo-reveal] link in page content).
  let photoRevealTimeout: number | null = null;
  let isTransitioning = false;

  function triggerPhotoReveal(imagePath: string) {
    const container = document.getElementById('titlePhotoContainer');
    if (!container || isTransitioning) return;
    const img = container.querySelector<HTMLImageElement>('.title-photo');
    if (!img) return;

    if (photoRevealTimeout) {
      clearTimeout(photoRevealTimeout);
      photoRevealTimeout = null;
    }

    const revealWithImage = () => {
      container.classList.add('revealed');
      photoRevealTimeout = window.setTimeout(() => {
        container.classList.remove('revealed');
        photoRevealTimeout = null;
      }, 2500);
    };

    const preloadAndReveal = () => {
      const preloader = new Image();
      preloader.onload = () => {
        img.src = imagePath;
        revealWithImage();
        isTransitioning = false;
      };
      preloader.onerror = () => { isTransitioning = false; };
      preloader.src = imagePath;
    };

    isTransitioning = true;

    if (container.classList.contains('revealed')) {
      container.classList.remove('revealed');
      setTimeout(preloadAndReveal, 300);
    } else {
      preloadAndReveal();
    }
  }

  function isTouchLikeInput() {
    return (
      window.matchMedia?.('(hover: none)').matches ||
      'ontouchstart' in window ||
      (window.navigator?.maxTouchPoints || 0) > 0
    );
  }

  function handleBackNavigation() {
    const currentUrl = window.location.href;
    const currentDomain = window.location.hostname;
    const referrer = document.referrer;

    if (!referrer) { window.location.href = '/'; return; }

    let referrerUrl: URL;
    try {
      referrerUrl = new URL(referrer);
    } catch {
      window.location.href = '/';
      return;
    }

    if (referrerUrl.hostname !== currentDomain) { window.location.href = '/'; return; }
    if (referrer === currentUrl) { window.location.href = '/'; return; }

    window.history.back();
  }

  // Delegated click handler — survives DOM swaps because it's on document.
  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement | null;
    if (!target) return;

    const photoTrigger = target.closest<HTMLElement>('[data-photo-reveal]');
    if (photoTrigger) {
      event.preventDefault();
      triggerPhotoReveal(photoTrigger.dataset.photoReveal || '/assets/images/site/me.jpg');
      return;
    }

    const siteName = target.closest<HTMLElement>('[data-site-name-trigger]');
    if (siteName) {
      event.preventDefault();
      const menu = document.getElementById('siteNameMenu');
      if (isTouchLikeInput() && menu) {
        menu.classList.toggle('is-open');
      } else {
        triggerPhotoReveal('/assets/images/site/me.jpg');
      }
      return;
    }

    const settingsTrigger = target.closest<HTMLElement>('[data-settings-trigger]');
    if (settingsTrigger) {
      event.preventDefault();
      document.dispatchEvent(new CustomEvent('settings:toggle'));
      return;
    }

    const backNav = target.closest<HTMLElement>('[data-back-nav]');
    if (backNav) {
      event.preventDefault();
      handleBackNavigation();
      return;
    }
  });

  // React to settings panel open/close to update the trigger link text and
  // the site-name menu's open class. SettingsPanel owns its state; we react.
  document.addEventListener('settings:state-changed', (e: Event) => {
    const isOpen = (e as CustomEvent<{ isOpen: boolean }>).detail.isOpen;
    const menu = document.getElementById('siteNameMenu');
    if (menu) menu.classList.toggle('is-open', isOpen);
    document.querySelectorAll('.settings-toggle-text').forEach(el => {
      el.textContent = isOpen ? 'close' : 'settings';
    });
  });
</script>
