---
import Icon from './Icon.astro';

interface Props {
  id: string;
  title: string;
  expanded?: boolean;
  class?: string;
}

const { id, title, expanded = false, class: extraClass } = Astro.props;
const wrapperClass = ['expandable-section', extraClass].filter(Boolean).join(' ');
---
<div class={wrapperClass} id={id} data-expandable-section>
  <button class="expandable-toggle" aria-expanded={expanded ? 'true' : 'false'}>
    <span class="toggle-text" set:html={title} />
    <span class="toggle-icon"><Icon name="plus" /></span>
  </button>
  <div class:list={['expandable-content', { collapsed: !expanded }]}>
    <slot />
  </div>
</div>

<script>
  // Self-owning expandable. Click toggles aria-expanded + max-height
  // animation. Sets data-expandable-init="true" so the legacy
  // ui-components.js initializer skips this element.
  function init(button: HTMLButtonElement) {
    if (button.dataset.expandableInit === 'true') return;
    button.dataset.expandableInit = 'true';

    const content = button.nextElementSibling as HTMLElement | null;
    if (!content) return;

    if (button.getAttribute('aria-expanded') !== 'true') {
      content.classList.add('collapsed');
    } else {
      content.classList.remove('collapsed');
    }

    button.addEventListener('click', () => {
      const isExpanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!isExpanded));

      if (isExpanded) {
        content.style.maxHeight = content.scrollHeight + 'px';
        // Force reflow so the next class change animates from the current height.
        void content.offsetHeight;
        content.classList.add('collapsed');
      } else {
        content.classList.remove('collapsed');
        content.style.maxHeight = content.scrollHeight + 'px';

        const handler = (e: Event) => {
          const transitionEvent = e as TransitionEvent;
          if (
            transitionEvent.propertyName === 'max-height' &&
            !content.classList.contains('collapsed')
          ) {
            content.style.maxHeight = '';
            content.removeEventListener('transitionend', handler);
          }
        };
        content.addEventListener('transitionend', handler);
      }
    });
  }

  function initAll() {
    document
      .querySelectorAll<HTMLDivElement>('[data-expandable-section]')
      .forEach(section => {
        const button = section.querySelector<HTMLButtonElement>('.expandable-toggle');
        if (button) init(button);
      });
  }

  document.addEventListener('astro:page-load', initAll);
</script>
