---
// Typed wrapper around the [data-zoomable] contract. From .astro:
//   <ZoomableImage src="/cool.jpg" alt="Cool" width={3943} height={2958} />
// From markdown (raw HTML, no Astro JSX available):
//   <img src="/cool.jpg" alt="Cool" data-zoomable width="3943" height="2958" loading="lazy">
// Both render an <img data-zoomable>; the singleton handler in image-zoom.ts
// decorates it on click.

interface Props {
  src: string;
  alt?: string;
  width?: number;
  height?: number;
  /** Caption text shown above the lightbox controls. */
  title?: string;
  /** Secondary metadata line (e.g. camera, date). */
  meta?: string;
  /** Higher-res source the lightbox upgrades to once the thumb has opened. */
  fullSrc?: string;
  loading?: 'eager' | 'lazy';
  class?: string;
}

const {
  src,
  alt = '',
  width,
  height,
  title,
  meta,
  fullSrc,
  loading = 'lazy',
  class: className,
} = Astro.props;
---
<img
  src={src}
  alt={alt}
  data-zoomable
  width={width}
  height={height}
  loading={loading}
  class={className}
  data-title={title}
  data-meta={meta}
  data-full-src={fullSrc}
/>

<script>
  // Import the lib so its document-level click handler is registered when
  // this component is on the page. Default.astro also imports it so that
  // markdown posts that hand-write <img data-zoomable> work even when this
  // component isn't rendered anywhere on the page.
  import '../lib/image-zoom.ts';
</script>
