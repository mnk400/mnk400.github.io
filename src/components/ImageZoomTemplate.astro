---
import Icon from './Icon.astro';
---
<template id="image-zoom-template">
  <div
    class="image-zoom-overlay"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
    tabindex="-1"
  >
    <button
      type="button"
      class="image-zoom-backdrop"
      aria-label="Close zoomed image"
      tabindex="-1"
      data-zoom-backdrop
    />

    <div class="image-zoom-controls" data-zoom-controls>
      <!-- Edge navigation. Hidden on touch (swipe handles it) and when the
           gallery has a single image. -->
      <button type="button" class="image-zoom-edge image-zoom-edge--prev" aria-label="Previous image" data-zoom-previous>
        <Icon name="caret-left" />
      </button>
      <button type="button" class="image-zoom-edge image-zoom-edge--next" aria-label="Next image" data-zoom-next>
        <Icon name="caret-right" />
      </button>

      <div class="image-zoom-corner">
        <span class="image-zoom-counter" data-zoom-counter />
        <button type="button" class="image-zoom-control-button image-zoom-share" aria-label="Copy link to image" data-zoom-share>
          <span data-zoom-share-link><Icon name="link" /></span>
          <span data-zoom-share-check hidden><Icon name="check" /></span>
        </button>
        <button type="button" class="image-zoom-control-button image-zoom-close" aria-label="Close zoomed image" data-zoom-close>
          <Icon name="x" />
        </button>
      </div>

      <!-- Bottom-center info, no controls: caption · detail. -->
      <div class="image-zoom-infobar">
        <div class="image-zoom-meta" data-zoom-meta>
          <span class="image-zoom-caption" data-zoom-caption />
          <span class="image-zoom-sep image-zoom-sep--meta" aria-hidden="true" data-zoom-meta-separator>·</span>
          <span class="image-zoom-detail" data-zoom-detail />
        </div>
      </div>
    </div>
  </div>
</template>
